# ==========================================
# Lighthouse Environment Variables Example
# ==========================================
# Copy this file to .env and fill in your actual API keys.
# DO NOT commit your actual .env file to version control.

# 🗺️ Location Services
# Required for real-time operational map and task geocoding
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# 🧠 Multi-Tier AI Matching Engine
# Primary AI Model (Required for Google hackathon compliance)
VITE_GEMINI_API_KEY=your_gemini_key_here
# Fallback AI Model (Required for rate-limit resilience)
VITE_GROQ_API_KEY=your_groq_key_here

# 🔥 Firebase Configuration
# Required for Authentication, Firestore Sync, and Cloud Messaging
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=1:your_app_id_here
